# ============================================================
# PLURIBUS — Configuration
# ============================================================

# Default: PrismML Bonsai 1-bit (free, local, 1.15GB, Apache 2.0)
# No API keys needed. Just start.
LLM_PROVIDER=bonsai

# Bonsai model options:
#   bonsai:8b   — 1.15 GB, best reasoning (default)
#   bonsai:4b   — 0.57 GB, fast
#   bonsai:1.7b — 0.24 GB, ultra-light (mobile/edge)
BONSAI_MODEL=bonsai:8b

# Alternative: Any Ollama model
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3:8b

# Cloud providers (optional, better reasoning, requires API key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...

# Server
PORT=3000
